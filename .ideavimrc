let mapleader = " "
let maplocalleader = ","

set scrolloff=15

set hlsearch
set incsearch
set ignorecase
set smartcase

set number
set relativenumber
set cursorline

set autoindent
set smartindent

set clipboard=unnamedplus
set visualbell
set t_vb=

set mini-ai
set which-key
set notimeout

Plug "machakann/vim-highlightedyank"
Plug "tpope/vim-commentary"
Plug "tpope/vim-surround"
Plug 'easymotion/vim-easymotion'

let g:highlightedyank_highlight_color = "rgba(114, 165, 219, 120)"

map Q gq
map Y y$
imap jj <Esc>

nnoremap <A-j> :m .+1<CR>==
nnoremap <A-k> :m .-2<CR>==
nnoremap <Esc> :nohlsearch<CR><Esc>

nnoremap <Leader>sf :action com.mituuz.fuzzier.Fuzzier<CR>
nnoremap <Leader>sw :action com.mituuz.fuzzier.FuzzyGrep<CR>
nnoremap <leader>lr :action RenameElement<CR>

nnoremap <Leader>fc :action ReformatCode<CR>
nnoremap <Leader>fo :action ReformatWithOptimizeImportsAction<CR>

