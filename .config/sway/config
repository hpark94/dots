set $mainMod Mod4
set $browser librewolf
set $fileManager thunar
set $menu fuzzel
set $terminal ghostty
set $wallpaper ~/Sync/.pictures/wallpaper/frieren.jpg
set $lockcmd swaylock -f -i $wallpaper
set $polkit lxpolkit

exec test -f /usr/libexec/sway-systemd/session.sh \
  && /usr/libexec/sway-systemd/session.sh \
  || dbus-update-activation-environment --systemd WAYLAND_DISPLAY XDG_CURRENT_DESKTOP=sway

exec systemctl --user start clipboard-tunnel.service
exec $polkit

exec swayidle -w \
    timeout 300 '$lockcmd' \
    timeout 600 'swaymsg "output * dpms off"' resume 'swaymsg "output * dpms on"' \
    timeout 900 'systemctl suspend' \
    before-sleep '$lockcmd'

exec protonvpn connect --p2p
exec swaybg -i $wallpaper
exec fcitx5 -d
exec waybar -c ~/.config/waybar/sway_config.jsonc
exec swaync
exec_always ~/.local/scripts/autotiling
exec pkill -f 'wl-paste.*cliphist' ; wl-paste --watch cliphist store

input "type:keyboard" {
    xkb_layout de
    xkb_variant nodeadkeys
}

input "type:touchpad" {
    natural_scroll enabled
    tap enabled
}

input "elan9008:00-04f3:2d4b-stylus" {
    map_to_output eDP-1
}

default_border pixel 3
default_floating_border pixel 3

gaps inner 3
gaps outer 6

client.focused #edbb9b #edbb9b #ffffff #edbb9b #edbb9b
client.focused_inactive #595959 #595959 #ffffff #595959 #595959

bindsym Control+Alt+t exec $terminal
bindsym Control+Alt+e exec $fileManager
bindsym Control+Alt+r exec $menu
bindsym Control+Alt+b exec $browser
bindsym Control+Alt+q kill
bindsym Control+Alt+c exec ~/.local/scripts/caffeine
bindsym Control+Alt+l exec $lockcmd
bindsym Control+Alt+f floating toggle
bindsym Control+Alt+m fullscreen toggle
bindsym Control+Alt+p exec sudo battery-threshold-toggle
bindsym Control+Alt+w exec pkill -USR1 waybar

bindsym Control+Alt+h splith
bindsym Control+Alt+v splith

bindsym $mainMod+h focus left
bindsym $mainMod+j focus down
bindsym $mainMod+k focus up
bindsym $mainMod+l focus right

bindsym $mainMod+Shift+h move left
bindsym $mainMod+Shift+j move down
bindsym $mainMod+Shift+k move up
bindsym $mainMod+Shift+l move right

bindsym $mainMod+1 workspace 1
bindsym $mainMod+2 workspace 2
bindsym $mainMod+3 workspace 3
bindsym $mainMod+4 workspace 4
bindsym $mainMod+5 workspace 5
bindsym $mainMod+6 workspace 6
bindsym $mainMod+7 workspace 7
bindsym $mainMod+8 workspace 8
bindsym $mainMod+9 workspace 9
bindsym $mainMod+0 workspace 10
bindsym $mainMod+p workspace 11

bindsym $mainMod+Shift+1 move container to workspace number 1; workspace number 1
bindsym $mainMod+Shift+2 move container to workspace number 2; workspace number 2
bindsym $mainMod+Shift+3 move container to workspace number 3; workspace number 3
bindsym $mainMod+Shift+4 move container to workspace number 4; workspace number 4
bindsym $mainMod+Shift+5 move container to workspace number 5; workspace number 5
bindsym $mainMod+Shift+6 move container to workspace number 6; workspace number 6
bindsym $mainMod+Shift+7 move container to workspace number 7; workspace number 7
bindsym $mainMod+Shift+8 move container to workspace number 8; workspace number 8
bindsym $mainMod+Shift+9 move container to workspace number 9; workspace number 9
bindsym $mainMod+Shift+0 move container to workspace number 10; workspace number 10
bindsym $mainMod+Shift+p move container to workspace number 11; workspace number 11

bindsym XF86AudioRaiseVolume exec wpctl set-mute @DEFAULT_AUDIO_SINK@ 0 && wpctl set-volume -l 1 @DEFAULT_AUDIO_SINK@ 5%+
bindsym XF86AudioLowerVolume exec wpctl set-mute @DEFAULT_AUDIO_SINK@ 0 && wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-
bindsym XF86AudioMute exec wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle

bindsym XF86MonBrightnessUp exec brightnessctl set 5%+
bindsym XF86MonBrightnessDown exec brightnessctl set 5%-

bindgesture swipe:right exec ~/.config/sway/scripts/swipe-workspace-dec.sh
bindgesture swipe:left exec ~/.config/sway/scripts/swipe-workspace-inc.sh

bindsym $mainMod+Shift+S exec grim -o $(swaymsg -t get_outputs | jq -r '.[] | select(.focused) | .name') - | satty -f -
bindsym Control+Alt+S exec grim -o $(swaymsg -t get_outputs | jq -r '.[] | select(.focused) | .name') ~/Bilder/Screenshots/screenshot-$(date +'%Y%m%d-%H%M%S').png && notify-send "Screenshot" "Gespeichert in ~/Bilder/Screenshots/"

