map r reload
map R reload
map i recolor
map b toggle_statusbar

set font "Maple Mono NF 15"
set pages-per-row 1
set zoom-min 10
set window-title-basename true
set window-title-page true
set scroll-page-aware true
set scroll-full-overlap 0.01
set scroll-step 100
set scroll-hstep 100
set selection-clipboard clipboard
set search-hadjust true
set render-loading true

set default-bg              "#100e11"
set default-fg              "#e9e6e2"
set statusbar-bg            "#100e11"
set statusbar-fg            "#e9e6e2"

set inputbar-bg             "#100e11"
set inputbar-fg             "#e9e6e2"

set highlight-color         "rgba(255, 255, 0, 0.2)"
set highlight-active-color  "rgba(255, 0, 0, 0.2)"

set notification-error-bg   "#d36969"
set notification-error-fg   "#100e11"
set notification-warning-bg "#d36969"
set notification-warning-fg "#100e11"

set completion-highlight-fg "#59c076"
set completion-highlight-bg "#100e11"
set completion-bg           "#100e11"
set completion-fg           "#e9e6e2"
set notification-bg         "#e9e6e2"
set notification-fg         "#100e11"
set highlight-fg            "#69acd3"

set recolor                 false
set recolor-lightcolor      "#100e11"
set recolor-darkcolor       "#e9e6e2"
set recolor-keephue         true
