map r reload
map R reload
map i recolor
map b toggle_statusbar

set font "Maple Mono NF 15"
set pages-per-row 1
set zoom-min 10
set window-title-basename true
set window-title-page true
set scroll-page-aware true
set scroll-full-overlap 0.01
set scroll-step 100
set scroll-hstep 100
set selection-clipboard clipboard
set search-hadjust true
set render-loading true

set default-bg              "#000000"
set default-fg              "#f9f7f6"
set statusbar-bg            "#000000"
set statusbar-fg            "#f9f7f6"

set inputbar-bg             "#000000"
set inputbar-fg             "#f9f7f6"

set highlight-color         "rgba(255, 255, 0, 0.2)"
set highlight-active-color  "rgba(255, 0, 0, 0.2)"

set notification-error-bg   "#fb6f92"
set notification-error-fg   "#000000"
set notification-warning-bg "#fb6f92"
set notification-warning-fg "#000000"

set completion-highlight-fg "#23B0A3"
set completion-highlight-bg "#000000"
set completion-bg           "#000000"
set completion-fg           "#f9f7f6"
set notification-bg         "#f9f7f6"
set notification-fg         "#000000"
set highlight-fg            "#007acc"

set recolor                 false
set recolor-lightcolor      "#000000"
set recolor-darkcolor       "#f9f7f6"
set recolor-keephue         true
