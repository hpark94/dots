#!/usr/bin/env bash
set -euo pipefail

theme_state_dir() {
	echo "${XDG_STATE_HOME:-$HOME/.local/state}/theme"
}

theme_state_file() {
	echo "$(theme_state_dir)/mode"
}

theme_config_dir() {
	echo "${XDG_CONFIG_HOME:-$HOME/.config}/theme"
}

theme_palette_file() {
	local mode=$1
	echo "$(theme_config_dir)/hp_${mode}.sh"
}

resolve_mode() {
	local requested=$1
	case "$requested" in
	dark | light)
		echo "$requested"
		;;
	toggle)
		local state_file
		state_file=$(theme_state_file)
		if [[ -f "$state_file" ]] && [[ "$(<"$state_file")" == "dark" ]]; then
			echo "light"
		else
			echo "dark"
		fi
		;;
	*)
		echo "usage: theme-switch dark|light|toggle" >&2
		return 1
		;;
	esac
}

write_state() {
	local mode=$1
	local state_dir
	state_dir=$(theme_state_dir)
	mkdir -p "$state_dir"
	printf '%s' "$mode" >"$state_dir/mode"
}

foot_colors_block() {
	local palette_file=$1
	# shellcheck disable=SC1090,SC2154
	(
		source "$palette_file"
		printf 'background=%s\n' "${bg#\#}"
		printf 'foreground=%s\n\n' "${fg#\#}"
		printf 'regular0=%s\n' "${color0#\#}"
		printf 'regular1=%s\n' "${color1#\#}"
		printf 'regular2=%s\n' "${color2#\#}"
		printf 'regular3=%s\n' "${color3#\#}"
		printf 'regular4=%s\n' "${color4#\#}"
		printf 'regular5=%s\n' "${color5#\#}"
		printf 'regular6=%s\n' "${color6#\#}"
		printf 'regular7=%s\n\n' "${color7#\#}"
		printf 'bright0=%s\n' "${color8#\#}"
		printf 'bright1=%s\n' "${color9#\#}"
		printf 'bright2=%s\n' "${color10#\#}"
		printf 'bright3=%s\n' "${color11#\#}"
		printf 'bright4=%s\n' "${color12#\#}"
		printf 'bright5=%s\n' "${color13#\#}"
		printf 'bright6=%s\n' "${color14#\#}"
		printf 'bright7=%s\n\n' "${color15#\#}"
		printf 'selection-foreground=%s\n' "${selection_fg#\#}"
		printf 'selection-background=%s\n' "${selection_bg#\#}"
	)
}

generate_foot() {
	local mode=$1 out_dir=$2
	mkdir -p "$out_dir"
	{
		printf 'initial-color-theme=%s\n\n' "$mode"
		printf '[colors-light]\n'
		foot_colors_block "$(theme_palette_file light)"
		printf '\n[colors-dark]\n'
		foot_colors_block "$(theme_palette_file dark)"
	} >"$out_dir/foot-colors.ini"
}

sway_client_line() {
	local group=$1 color=$2
	printf 'client.%s %s %s #ffffff %s %s' "$group" "$color" "$color" "$color" "$color"
}

generate_sway() {
	local mode=$1 out_dir=$2
	mkdir -p "$out_dir"
	# shellcheck disable=SC1090,SC2154
	(
		source "$(theme_palette_file "$mode")"
		{
			printf '%s\n' "$(sway_client_line focused "$color11")"
			printf '%s\n' "$(sway_client_line focused_inactive "$color8")"
		} >"$out_dir/sway-colors.conf"
	)
}

generate_ghostty() {
	local mode=$1 out_dir=$2
	mkdir -p "$out_dir"
	printf 'theme = "hp_%s"\n' "$mode" >"$out_dir/ghostty-theme.conf"
}

tmux_option_pairs() {
	local mode=$1
	local -n _tmux_option_pairs_out=$2
	# shellcheck disable=SC1090,SC2154
	mapfile -t _tmux_option_pairs_out < <(
		source "$(theme_palette_file "$mode")"
		printf '%s\n' \
			"window-status-style" "fg=$color4" \
			"window-status-current-style" "fg=$bg,bold,bg=$color4" \
			"display-panes-colour" "$color4" \
			"display-panes-active-colour" "$color3" \
			"status-style" "fg=$fg,bg=$bg" \
			"status-left" "#[fg=$color4,bold] #S #[default] " \
			"status-right" "#[fg=$fg] %H:%M #[fg=$color4,bold] #H " \
			"message-style" "fg=$color5" \
			"mode-style" "bg=$color12"
	)
}

generate_tmux() {
	local mode=$1 out_dir=$2
	mkdir -p "$out_dir"
	local pairs i
	tmux_option_pairs "$mode" pairs
	{
		for ((i = 0; i < ${#pairs[@]}; i += 2)); do
			printf 'set -g %s "%s"\n' "${pairs[i]}" "${pairs[i + 1]}"
		done
	} >"$out_dir/tmux-colors.conf"
}

generate_shell_env() {
	local mode=$1 out_dir=$2
	mkdir -p "$out_dir"
	# shellcheck disable=SC1090,SC2154
	(
		source "$(theme_palette_file "$mode")"
		{
			# args map 1:1 onto: fg,bg,hl / fg+,bg+,hl+ / info,prompt,pointer / marker,spinner,header
			printf "export FZF_DEFAULT_OPTS='--color=fg:%s,bg:%s,hl:%s --color=fg+:%s,bg+:%s,hl+:%s --color=info:%s,prompt:%s,pointer:%s --color=marker:%s,spinner:%s,header:%s'\n" \
				"$fg" "$bg" "$fg" "$fg" "$selection_bg" "$fg" "$color4" "$color5" "$color1" "$color2" "$color5" "$color3"
			printf 'export BAT_THEME=%s\n' "$mode"
		} >"$out_dir/shell-env.sh"
	)
}

apply_foot() {
	local mode=$1 sig=USR2
	[[ "$mode" == "dark" ]] && sig=USR1
	pkill -"$sig" -x foot >/dev/null 2>&1 || true
}

apply_sway() {
	local mode=$1
	if [[ -n "${SWAYSOCK:-}" ]] && command -v swaymsg >/dev/null 2>&1; then
		# shellcheck disable=SC1090,SC2154
		(
			source "$(theme_palette_file "$mode")"
			swaymsg "$(sway_client_line focused "$color11")" >/dev/null 2>&1 || true
			swaymsg "$(sway_client_line focused_inactive "$color8")" >/dev/null 2>&1 || true
		)
	fi
}

apply_tmux() {
	local mode=$1
	if command -v tmux >/dev/null 2>&1 && tmux list-sessions >/dev/null 2>&1; then
		local pairs i
		tmux_option_pairs "$mode" pairs
		for ((i = 0; i < ${#pairs[@]}; i += 2)); do
			tmux set-option -g "${pairs[i]}" "${pairs[i + 1]}" >/dev/null 2>&1 || true
		done
	fi
}

apply_gtk() {
	local mode=$1 gtk_theme=Adwaita-light color_scheme=prefer-light
	if [[ "$mode" == "dark" ]]; then
		gtk_theme=Adwaita-dark
		color_scheme=prefer-dark
	fi
	if command -v gsettings >/dev/null 2>&1; then
		gsettings set org.gnome.desktop.interface gtk-theme "$gtk_theme" >/dev/null 2>&1 || true
		gsettings set org.gnome.desktop.interface color-scheme "$color_scheme" >/dev/null 2>&1 || true
	fi
}

notify_mode() {
	local mode=$1
	if command -v notify-send >/dev/null 2>&1; then
		notify-send "Theme" "Switched to $mode mode" || true
	fi
}

main() {
	local mode out_dir
	mode=$(resolve_mode "${1:-toggle}")
	write_state "$mode"

	out_dir=$(theme_state_dir)
	generate_foot "$mode" "$out_dir"
	generate_sway "$mode" "$out_dir"
	generate_ghostty "$mode" "$out_dir"
	generate_tmux "$mode" "$out_dir"
	generate_shell_env "$mode" "$out_dir"

	apply_foot "$mode"
	apply_sway "$mode"
	apply_tmux "$mode"
	apply_gtk "$mode"

	notify_mode "$mode"
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
	main "$@"
fi
